{
  "$schema": "https://opencode.ai/config.json",
  // https://models.dev
  // https://docs.github.com/en/copilot/concepts/billing/copilot-requests#model-multipliers

  // opencode models --verbose

  // x3
  // "model": "github-copilot-enterprise/claude-opus-4.5",
  // x1
  // "model": "github-copilot-enterprise/claude-sonnet-4.5",
  // Free
  // "model": "github-copilot-enterprise/gpt-4.1",
  // "model": "github-copilot-enterprise/oswe-vscode-prime",
  // "model": "github-copilot-enterprise/grok-code-fast-1",

  "model": "github-copilot-enterprise/gpt-5-mini",
  "small_model": "github-copilot-enterprise/gpt-5-mini",
  "theme": "catppuccin",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://10.26.1.1:11434/"
      },
      "models": {
        "llama3.2:latest": {}
      }
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "model": "github-copilot-enterprise/claude-sonnet-4.5",
    },
    "build-easy": {
      "mode": "primary",
      "model": "github-copilot-enterprise/oswe-vscode-prime",
    },
    "build-zen": {
      "mode": "primary",
      "model": "opencode/glm-4.7-free",
    },
    "build-zen-fast": {
      "mode": "primary",
      "model": "opencode/grok-code",
      // "model": "opencode/minimax-m2.1-free",
    },
    "plan": {
      "mode": "primary",
      "model": "github-copilot-enterprise/claude-sonnet-4.5",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "plan-big": {
      "mode": "primary",
      "model": "github-copilot-enterprise/claude-opus-4.5",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "quick": {
      "mode": "primary",
      "model": "github-copilot-enterprise/gpt-5-mini",
      "description": "Fast reasoning with limited iterations",
      "prompt": "You are a quick thinker. Solve problems with minimal steps.",
      "maxSteps": 5
    },
  }
}
